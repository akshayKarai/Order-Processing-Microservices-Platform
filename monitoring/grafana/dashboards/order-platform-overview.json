{
  "title": "Order Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests per second by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "JVM Memory Used by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP 5xx error rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "p99 request latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, application))",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
